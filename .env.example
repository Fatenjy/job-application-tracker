POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobtracker
# "localhost" when running the API on the host; "db" when running inside docker compose
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Signs the JWT auth tokens. Use a long random string in production, e.g.
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-me-in-production

# Notifications — configure email (SMTP), Telegram, or both
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_USER=your address, SMTP_PASSWORD=an app password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Comma-separated keywords matched against job title and tags (empty = no notifications)
MATCH_KEYWORDS=python,junior,data
SCRAPE_INTERVAL_HOURS=6
